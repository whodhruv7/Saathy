# Copy this file to .env.local. Never commit real keys.
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

VITE_OPENROUTER_KEY=your_openrouter_key_here
VITE_GROQ_KEY=your_groq_key_here
VITE_GEMINI_KEY=your_gemini_key_here

# Keep false unless your Supabase project has a compatible chats table + RLS.
VITE_ENABLE_REMOTE_CHATS=false

# Deployment script environment variables (for .bat and .sh files)
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
